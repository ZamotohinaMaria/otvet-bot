# Ozon Seller API
OZON_CLIENT_ID=your_client_id
OZON_API_KEY=your_api_key

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_group_chat_id   # отрицательное число для группы, например -1001234567890

# LLM (выбери один провайдер)
LLM_PROVIDER=deepseek                  # deepseek | openai | claude
LLM_API_KEY=your_llm_api_key

# Настройки бота
MODE=semi                              # semi | auto
POLL_INTERVAL_MINUTES=15
DRY_RUN=false                          # true = не отправлять ответы на Ozon (для тестирования)
